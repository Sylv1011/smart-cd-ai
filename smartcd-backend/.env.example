# Set this to production on Railway/Render for strict CORS behavior.
ENVIRONMENT=staging

# Environment-specific database URLs:
# - ENVIRONMENT=production requires PROD_DATABASE_URL
# - ENVIRONMENT=staging requires STAGING_DATABASE_URL
# - ENVIRONMENT=development uses STAGING_DATABASE_URL or fallback DATABASE_URL
PROD_DATABASE_URL=postgresql://username:password@prod-host:5432/postgres?sslmode=require
STAGING_DATABASE_URL=postgresql://username:password@staging-host:5432/postgres?sslmode=require

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Production CORS allowlist is required:
PROD_CORS_ALLOWED_ORIGINS=https://app.example.com
# Staging/development can use this override or local defaults:
STAGING_CORS_ALLOWED_ORIGINS=http://localhost:5173,https://staging-app.example.com
