## Ranking Engine (FastAPI)
# Choose data backend:
#   - supabase: requires SUPABASE_URL + SUPABASE_*_KEY
#   - static:   deterministic local demo dataset
SMARTCD_DATA_MODE=static

# Supabase (required when SMARTCD_DATA_MODE=supabase)
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_ANON_KEY=

# CORS (comma-separated). Use your Vercel URL in production.
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Logging
LOG_LEVEL=INFO
