## Ranking Engine (FastAPI) - Production (Render)
ENVIRONMENT=production
SMARTCD_DATA_MODE=supabase

# Supabase (required)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# or: SUPABASE_ANON_KEY=

# CORS (set to your Vercel frontend domain)
CORS_ALLOW_ORIGINS=https://smartcd-ai.vercel.app

LOG_LEVEL=INFO

